# =============================================
# API 密钥配置（从下面选一个填入）
# =============================================

# --- 国际平台 ---
# OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key
# GOOGLE_API_KEY=your_google_api_key
# GROQ_API_KEY=your_groq_api_key
# MISTRAL_API_KEY=your_mistral_api_key

# --- 国内平台 ---
# DEEPSEEK_API_KEY=your_deepseek_api_key
# ALIYUN_API_KEY=your_aliyun_api_key
# ZHIPU_API_KEY=your_zhipu_api_key
# MOONSHOT_API_KEY=your_moonshot_api_key
# DOUBAO_API_KEY=your_doubao_api_key
# MINIMAX_API_KEY=your_minimax_api_key

# =============================================
# 默认模型（与上方密钥对应，选一个）
# =============================================
# DEFAULT_MODEL=gpt-4o                        # OpenAI
# DEFAULT_MODEL=claude-3-5-sonnet-20241022    # Anthropic
# DEFAULT_MODEL=gemini-2.0-flash              # Google
# DEFAULT_MODEL=llama-3.3-70b-versatile       # Groq（需配合 provider='groq'）
# DEFAULT_MODEL=mistral-large-latest          # Mistral
# DEFAULT_MODEL=deepseek-chat                 # DeepSeek
# DEFAULT_MODEL=qwen-plus                     # 通义千问
# DEFAULT_MODEL=glm-4                         # 智谱AI
# DEFAULT_MODEL=moonshot-v1-32k               # 月之暗面 Kimi
# DEFAULT_MODEL=doubao-pro-32k                # 字节豆包
# DEFAULT_MODEL=abab6.5s-chat                 # MiniMax

# 可选：自定义 API 地址（不需要修改则无需填写）
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# MISTRAL_BASE_URL=https://api.mistral.ai/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# 应用配置
DEBUG=false
LOG_LEVEL=INFO

# 日志文件配置
# LOG_TO_FILE=true
# LOG_FILE_PATH=./logs/research_agent.log
# LOG_FILE_MAX_BYTES=10485760
# LOG_FILE_BACKUP_COUNT=5

# 搜索配置
ARXIV_MAX_RESULTS=10
SEARCH_TIMEOUT=30
